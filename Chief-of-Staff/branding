        new TextRun({ children: [PageNumber.CURRENT], font: "Arial", size: 16, color: CS_MID_GRAY }),
      ]
    })
  ]
})
```

## Reusable Paragraph Helpers

These helpers should be defined in every document script. They enforce consistent styling:

```javascript
// Section header with orange bottom border
function sectionHeader(text) {
  return new Paragraph({
    spacing: { before: 360, after: 120 },
    border: { bottom: { style: BorderStyle.SINGLE, size: 6, color: CS_ORANGE, space: 4 } },
    children: [new TextRun({ text, font: "Arial", size: 28, bold: true, color: CS_DARK })]
  });
}

// Standard body paragraph
function bodyPara(text) {
  return new Paragraph({
    spacing: { after: 160, line: 276 },
    children: [new TextRun({ text, font: "Arial", size: 22, color: CS_GRAY })]
  });
}

// Bullet with bold lead-in label
function boldBulletItem(boldText, normalText, reference = "bullets") {
  return new Paragraph({
    numbering: { reference, level: 0 },
    spacing: { after: 80, line: 276 },
    children: [
      new TextRun({ text: boldText, font: "Arial", size: 22, color: CS_DARK, bold: true }),
      new TextRun({ text: normalText, font: "Arial", size: 22, color: CS_GRAY })
    ]
  });
}

// Sub-label (bold, smaller than section header)
function subLabel(text) {
  return new Paragraph({
    spacing: { before: 200, after: 80 },
    children: [new TextRun({ text, font: "Arial", size: 22, bold: true, color: CS_MID_GRAY })]
  });
}

// Metadata table row
function metaRow(label, value, col1W = 2400, col2W = 6960) {
  return new TableRow({
    children: [
      new TableCell({ borders, width: { size: col1W, type: WidthType.DXA },
        shading: lightCellShading, margins: cellMargins,
        children: [new Paragraph({ children: [new TextRun({ text: label, font: "Arial", size: 20, bold: true, color: CS_DARK })] })] }),
      new TableCell({ borders, width: { size: col2W, type: WidthType.DXA },
        margins: cellMargins,
        children: [new Paragraph({ children: [new TextRun({ text: value, font: "Arial", size: 20, color: CS_GRAY })] })] })
    ]
  });
}

// TL;DR / callout box (orange left border)
function calloutBox(children) {
  return new Table({
    width: { size: 9360, type: WidthType.DXA },
    columnWidths: [9360],
    rows: [new TableRow({ children: [
      new TableCell({
        borders: {
          top: { style: BorderStyle.SINGLE, size: 1, color: CS_ORANGE },
          bottom: { style: BorderStyle.SINGLE, size: 1, color: CS_ORANGE },
          left: { style: BorderStyle.SINGLE, size: 12, color: CS_ORANGE },
          right: { style: BorderStyle.SINGLE, size: 1, color: CS_ORANGE },
        },
        width: { size: 9360, type: WidthType.DXA },
        shading: accentCellShading,
        margins: { top: 120, bottom: 120, left: 200, right: 200 },
        children,
      })
    ] })]
  });
}
```

## Unbranded Variant

If the user is not at CentralSquare or requests unbranded output, substitute:

| Branded | Unbranded |
|---------|-----------|
| CS_ORANGE (#ED591F) | Professional Blue (#2A7BC8) |
| CS_DARK (#1E2A3A) | Dark Slate (#2D3748) |
| CS_ACCENT_BG (#FFF0EB) | Light Blue (#EBF5FF) |
| Header: "CENTRALSQUARE TECHNOLOGIES" | Header: omit or use user's org name |
